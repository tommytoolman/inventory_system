# ============================================================
# Discord Logger — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored; NEVER commit real secrets.

# -----------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------

# Discord webhook URL for the #system-alerts channel.
# Get this from: Discord channel → Edit → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/1480547611973910670/0vZ388OU5t-ZJwx9HAWSofaEyHsP4dOHdBF4P7yjU4fymiepP1BLM6G8VUaEV9xjsGNT

# -----------------------------------------------------------
# OPTIONAL — all have sensible defaults
# -----------------------------------------------------------

# Name shown in every Discord embed footer (default: "RIFF")
DISCORD_SERVICE_NAME=RIFF

# Set to "false" to completely disable Discord logging (e.g. in local dev)
DISCORD_LOGGING_ENABLED=true

# How often (milliseconds) to flush the log queue to Discord (default: 5000)
DISCORD_BATCH_INTERVAL=5000

# Maximum number of log entries held in memory before oldest are dropped (default: 1000)
DISCORD_QUEUE_LIMIT=1000

# -----------------------------------------------------------
# STANDARD NODE.JS
# -----------------------------------------------------------

# "production" | "development" | "test"
# Used in embed footers so you know which environment the log came from.
NODE_ENV=production
