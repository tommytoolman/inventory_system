{
  "name": "discord-logger",
  "version": "1.0.0",
  "description": "Production-grade Discord webhook logger for RIFF applications",
  "main": "dist/utils/discordLogger.js",
  "types": "dist/utils/discordLogger.d.ts",
  "scripts": {
