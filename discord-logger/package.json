    "@types/node":     "^20.14.0",
    "express":         "^4.19.2",
    "jest":            "^29.7.0",
    "ts-jest":         "^29.1.5",
    "ts-node":         "^10.9.2",
    "typescript":      "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
